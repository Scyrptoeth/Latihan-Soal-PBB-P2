# Upstash Redis credentials (required for central anonymous feedback & rating analytics)
# Get these from your Upstash Redis dashboard after creating a database.
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# Developer rating dashboard admin token (used for /api/feedback and /api/ratings)
RATING_ADMIN_TOKEN=<generate-a-strong-random-token>
